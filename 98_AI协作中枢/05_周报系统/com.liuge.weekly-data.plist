<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.liuge.weekly-data</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>/Users/davidliu/KnowledgeBase/retail-knowledge-vault/98_AI协作中枢/05_周报系统/weekly_data.sh</string>
  </array>

  <!-- 每周日 07:00 北京时间 = UTC 周六 23:00 (Weekday=6) -->
  <key>StartCalendarInterval</key>
  <dict>
    <key>Weekday</key>
    <integer>6</integer>
    <key>Hour</key>
    <integer>23</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>

  <key>StandardOutPath</key>
  <string>/tmp/weekly_data.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/weekly_data.err</string>

  <key>RunAtLoad</key>
  <false/>
</dict>
</plist>
